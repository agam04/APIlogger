# Copy this file to .env and fill in values before running docker compose

# ── AI — set ONE of these (Anthropic takes priority; Groq is free) ──────────
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk# free at console.groq.com

# ── Email alerts (optional) ──────────────────────────────────────────────────
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ── Security (change in production!) ────────────────────────────────────────
SECRET_KEY=dev-secret-change-me-run-openssl-rand-hex-32
